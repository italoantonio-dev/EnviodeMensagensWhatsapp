{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "node config-server.js"
  },
  "volumes": [
    {
      "name": "baileys-auth",
      "path": "/app/baileys-auth"
    },
    {
      "name": "app-data",
      "path": "/app/data"
    }
  ]
}
